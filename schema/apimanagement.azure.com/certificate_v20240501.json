      "properties": {
        "azureName": {
          "type": "string",
          "maxLength": 80,
          "minLength": 1,
          "pattern": "^[^*#\u0026+:\u003c\u003e?]+$"
        },
        "data": {
          "type": "object",
          "required": [
            "key",
            "name"
          ],
          "properties": {
            "key": {
              "type": "string"
