{
  "properties": {
    "spec": {
      "properties": {
        "domains": {
          "type": "array",
          "maxItems": 1,
          "items": {
            "type": "string",
            "maxLength": 63,
            "pattern": "^(([a-zA-Z0-9]+|[a-zA-Z0-9][-a-zA-Z0-9]*[a-zA-Z0-9])\\.)+[a-zA-Z][-a-zA-Z0-9]*[a-zA-Z0-9]\\.?$"
          }
        }
      }
    },
    "status": {
      "properties": {
        "certificateName": {
          "type": "string"
        },
        "certificateStatus": {
          "type": "string"
        },
        "domainStatus": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "domain",
              "status"
            ],
            "properties": {
              "domain": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "expireTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
