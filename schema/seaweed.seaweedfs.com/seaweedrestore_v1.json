{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "clusterName"
      ],
      "properties": {
        "backupName": {
          "type": "string"
        },
        "backupSource": {
          "type": "object",
          "required": [
            "metaPath",
            "storageName"
          ],
          "properties": {
            "metaPath": {
              "type": "string",
              "minLength": 1
            },
            "storageName": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "clusterName": {
          "type": "string",
          "minLength": 1,
          "x-kubernetes-validations": [
            {
              "rule": "self == oldSelf",
              "message": "clusterName is immutable"
            }
          ]
        },
        "filerPath": {
          "type": "string",
          "default": "/"
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "has(self.backupName) != has(self.backupSource)",
          "message": "exactly one of backupName or backupSource must be set"
        }
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "completionTime": {
          "type": "string",
          "format": "date-time"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-map-keys": [
            "type"
          ],
          "x-kubernetes-list-type": "map"
        },
        "jobName": {
          "type": "string"
        },
        "observedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "phase": {
          "type": "string",
          "enum": [
            "Pending",
            "Running",
            "Completed",
            "Failed"
          ]
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
