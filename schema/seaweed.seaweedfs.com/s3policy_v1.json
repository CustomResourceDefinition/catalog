{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "seaweedRef"
      ],
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "x-kubernetes-validations": [
            {
              "rule": "oldSelf == '' || self == oldSelf",
              "message": "policy name is immutable once set"
            }
          ]
        },
        "policyDocument": {
          "type": "string"
        },
        "reclaimPolicy": {
          "type": "string",
          "default": "Delete",
          "enum": [
            "Delete",
            "Retain"
          ]
        },
        "seaweedRef": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "statements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "actions",
              "effect",
              "resources"
            ],
            "properties": {
              "actions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                },
                "x-kubernetes-list-type": "set"
              },
              "effect": {
                "type": "string",
                "enum": [
                  "Allow",
                  "Deny"
                ]
              },
              "resources": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                },
                "x-kubernetes-list-type": "set"
              },
              "sid": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-type": "atomic"
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "(has(self.statements) \u0026\u0026 size(self.statements) \u003e 0) != (has(self.policyDocument) \u0026\u0026 size(self.policyDocument) \u003e 0)",
          "message": "set exactly one of spec.statements or spec.policyDocument"
        }
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-map-keys": [
            "type"
          ],
          "x-kubernetes-list-type": "map"
        },
        "observedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "phase": {
          "type": "string",
          "enum": [
            "Pending",
            "Ready",
            "Failed",
            "Terminating"
          ]
        },
        "policyName": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
