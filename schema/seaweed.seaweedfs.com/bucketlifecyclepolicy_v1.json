                  "days": {
                    "type": "integer",
                    "format": "int32",
                    "minimum": 1
                  },
                  "expiredObjectDeleteMarker": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "x-kubernetes-validations": [
                  {
                    "rule": "has(self.days) || (has(self.expiredObjectDeleteMarker) \u0026\u0026 self.expiredObjectDeleteMarker)",
                    "message": "expiration must set days or expiredObjectDeleteMarker"
                  }
                ]
              },
              "id": {
                "type": "string",
                "maxLength": 255,
                "minLength": 1
