{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "clusterRef"
      ],
      "properties": {
        "access": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "actions",
              "user"
            ],
            "properties": {
              "actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "Read",
                    "Write",
                    "List",
                    "Tagging",
                    "Admin"
                  ]
                },
                "x-kubernetes-list-type": "set"
              },
              "user": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-map-keys": [
            "user"
          ],
          "x-kubernetes-list-type": "map"
        },
        "anonymousRead": {
          "type": "boolean",
          "default": false
        },
        "clusterRef": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$",
          "x-kubernetes-validations": [
            {
              "rule": "!self.contains('..')",
              "message": "bucket name must not contain consecutive dots"
            },
            {
              "rule": "!self.matches('^[0-9]+[.][0-9]+[.][0-9]+[.][0-9]+$')",
              "message": "bucket name must not be in IPv4 format"
            },
            {
              "rule": "oldSelf == '' || self == oldSelf",
              "message": "bucket name is immutable once set"
            }
          ]
        },
        "objectLock": {
          "type": "boolean",
          "default": false,
          "x-kubernetes-validations": [
            {
              "rule": "!oldSelf || self",
              "message": "objectLock cannot be disabled once enabled"
            }
          ]
        },
        "owner": {
          "type": "string",
          "maxLength": 256
        },
        "placement": {
          "type": "object",
          "properties": {
            "dataCenter": {
              "type": "string"
            },
            "dataNode": {
              "type": "string"
            },
            "diskType": {
              "type": "string"
            },
            "fsync": {
              "type": "boolean",
              "default": false
            },
            "rack": {
              "type": "string"
            },
            "readOnly": {
              "type": "boolean",
              "default": false
            },
            "replication": {
              "type": "string",
              "pattern": "^[0-9]{3}$"
            },
            "ttl": {
              "type": "string",
              "pattern": "^[1-9][0-9]*[mhdwMy]$"
            },
            "volumeGrowthCount": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            },
            "worm": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        },
        "quota": {
          "type": "object",
          "required": [
            "size"
          ],
          "properties": {
            "enforce": {
              "type": "boolean",
              "default": true
            },
            "size": {
              "pattern": "^(\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))(([KMGTPE]i)|[numkMGTPE]|([eE](\\+|-)?(([0-9]+(\\.[0-9]*)?)|(\\.[0-9]+))))?$",
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ],
              "x-kubernetes-int-or-string": true
            }
          },
          "additionalProperties": false,
          "x-kubernetes-validations": [
            {
              "rule": "!string(self.size).startsWith('-')",
              "message": "quota.size must be non-negative"
            }
          ]
        },
        "reclaimPolicy": {
          "type": "string",
          "default": "Retain",
          "enum": [
            "Retain",
            "Delete"
          ]
        },
        "versioning": {
          "type": "string",
          "default": "Off",
          "enum": [
            "Off",
            "Enabled",
            "Suspended"
          ],
          "x-kubernetes-validations": [
            {
              "rule": "self != 'Off' || oldSelf == 'Off'",
              "message": "cannot disable versioning once it has been Enabled or Suspended; use Suspended instead"
            }
          ]
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "!self.objectLock || self.versioning == 'Enabled'",
          "message": "objectLock requires versioning: Enabled"
        }
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "bucketName": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-map-keys": [
            "type"
          ],
          "x-kubernetes-list-type": "map"
        },
        "objectLockEnabled": {
          "type": "boolean"
        },
        "observedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "ownerIdentity": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": [
            "Pending",
            "Ready",
            "Failed",
            "Terminating"
          ]
        },
        "quota": {
          "type": "object",
          "properties": {
            "enforced": {
              "type": "boolean"
            },
            "sizeBytes": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false
        },
        "usage": {
          "type": "object",
          "properties": {
            "lastUpdated": {
              "type": "string",
              "format": "date-time"
            },
            "objectCount": {
              "type": "integer",
              "format": "int64"
            },
            "sizeBytes": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false
        },
        "versioning": {
          "type": "string",
          "enum": [
            "Off",
            "Enabled",
            "Suspended"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "x-kubernetes-validations": [
    {
      "rule": "has(self.spec.name) || (self.metadata.name.matches('^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$') \u0026\u0026 !self.metadata.name.contains('..') \u0026\u0026 !self.metadata.name.matches('^[0-9]+[.][0-9]+[.][0-9]+[.][0-9]+$'))",
      "message": "when spec.name is unset, metadata.name must satisfy the S3 bucket naming rules (3-63 chars, lowercase alnum/hyphen/dot, no consecutive dots, not IPv4-shaped)"
    }
  ]
}
