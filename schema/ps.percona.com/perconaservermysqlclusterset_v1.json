{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "clusters",
        "credentialsSecret",
        "mysqlshellRunner",
        "primaryCluster"
      ],
      "properties": {
        "clusters": {
          "type": "array",
          "maxItems": 10,
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "endpoints",
              "innodbClusterName"
            ],
            "properties": {
              "endpoints": {
                "type": "array",
                "maxItems": 9,
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "host"
                  ],
                  "properties": {
                    "host": {
                      "type": "string",
                      "maxLength": 253,
                      "x-kubernetes-validations": [
                        {
                          "rule": "isIP(self) || !format.dns1123Subdomain().validate(self).hasValue()",
                          "message": "host must be a valid IP address or domain name"
                        }
                      ]
                    },
                    "port": {
                      "type": "integer",
                      "format": "int32",
                      "default": 3306
                    }
                  },
                  "additionalProperties": false
                }
              },
              "innodbClusterName": {
                "type": "string",
                "maxLength": 63,
                "x-kubernetes-validations": [
                  {
                    "rule": "self.matches('^[A-Za-z0-9]+$')",
                    "message": "innodbClusterName must contain only alphanumeric characters"
                  }
                ]
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-map-keys": [
            "innodbClusterName"
          ],
          "x-kubernetes-list-type": "map",
          "x-kubernetes-validations": [
            {
              "rule": "self.all(c, self.exists_one(d, d.innodbClusterName == c.innodbClusterName))",
              "message": "cluster names must be unique"
            }
          ]
        },
        "createReplicaClusterOptions": {
          "type": "object",
          "properties": {
            "recoveryMethod": {
              "type": "string",
              "default": "clone",
              "enum": [
                "clone",
                "incremental",
                "auto"
              ]
            }
          },
          "additionalProperties": false
        },
        "credentialsSecret": {
          "type": "object",
          "required": [
            "key"
          ],
          "properties": {
            "key": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "default": ""
            },
            "optional": {
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "x-kubernetes-map-type": "atomic",
          "x-kubernetes-validations": [
            {
              "rule": "has(self.name) \u0026\u0026 self.name != ''",
              "message": "credentialsSecret.name must be set"
            }
          ]
        },
        "mysqlshellRunner": {
          "type": "object",
          "required": [
            "image"
          ],
          "properties": {
            "image": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "primaryCluster": {
          "type": "string",
          "maxLength": 63,
          "x-kubernetes-validations": [
            {
              "rule": "self.matches('^[A-Za-z0-9]+$')",
              "message": "primaryCluster must contain only alphanumeric characters"
            }
          ]
        },
        "sslMode": {
          "type": "string",
          "default": "AUTO",
          "enum": [
            "AUTO",
            "DISABLED",
            "REQUIRED",
            "VERIFY_CA",
            "VERIFY_IDENTITY"
          ]
        },
        "unsafeFlags": {
          "type": "object",
          "properties": {
            "forcedClusterRemoval": {
              "type": "boolean",
              "default": false
            },
            "forcedFailover": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "self.clusters.exists(c, c.innodbClusterName == self.primaryCluster)",
          "message": "spec.primaryCluster not found in spec.clusters"
        },
        {
          "rule": "self.clusters.all(c, c.endpoints.all(e, self.clusters.map(c2, c2.endpoints.filter(e2, e2.host == e.host).size()).sum() == 1))",
          "message": "endpoint host must be unique across all clusters"
        }
      ]
    },
    "status": {
      "type": "object",
      "required": [
        "primaryCluster",
        "primaryClusterEndpoint"
      ],
      "properties": {
        "clusters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "clusterRole",
              "globalStatus",
              "primary"
            ],
            "properties": {
              "clusterRole": {
                "type": "string"
              },
              "globalStatus": {
                "type": "string"
              },
              "primary": {
                "type": "string"
              }
            }
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          }
        },
        "lastObservedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastObservedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "primaryCluster": {
          "type": "string"
        },
        "primaryClusterEndpoint": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
