{
  "description": "TwingateResourceAccess represents a resource access policy in Twingate. It allows to configure an access between a Resource and a Principal which is either a Group or a ServiceAccount.",
  "type": "object",
  "required": [
    "spec"
  ],
  "properties": {
    "spec": {
      "description": "TwingateResourceAccessSpec defines the desired state of TwingateResourceAccess",
      "type": "object",
      "oneOf": [
        {
          "required": [
            "resourceRef",
            "principalId"
          ]
        },
        {
          "required": [
            "resourceRef",
            "principalExternalRef"
          ]
        },
        {
          "required": [
            "resourceRef",
            "groupRef"
          ]
        }
      ],
      "properties": {
        "accessPolicy": {
          "description": "Access policy applied to this access edge. Omitting the field or setting it to null clears any existing policy. Must be null when the principal is a ServiceAccount.",
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "durationSeconds": {
              "description": "Duration of the access policy in seconds. Used with AUTO_LOCK and ACCESS_REQUEST mode.",
              "type": "integer",
              "maximum": 31536000,
              "minimum": 3600,
              "nullable": true
            },
            "mode": {
              "description": "Access mode.",
              "type": "string",
              "enum": [
                "MANUAL",
                "AUTO_LOCK",
                "ACCESS_REQUEST"
              ]
            }
          },
          "additionalProperties": false,
          "nullable": true,
          "x-kubernetes-validations": [
            {
              "rule": "self.mode != 'AUTO_LOCK' || has(self.durationSeconds)",
              "message": "durationSeconds is required when mode is AUTO_LOCK"
            },
            {
              "rule": "self.mode != 'MANUAL' || !has(self.durationSeconds)",
              "message": "durationSeconds must not be set when mode is MANUAL"
            }
          ]
        },
        "approvalMode": {
          "description": "Approval mode for the access edge. Omitting the field or setting it to null clears any existing value. Must be null when the principal is a ServiceAccount.",
          "type": "string",
          "enum": [
            "MANUAL",
            "AUTOMATIC"
          ],
          "nullable": true
        },
        "expiresAt": {
          "description": "RFC3339 datetime when this access expires. Omitting the field or setting it to null clears any existing expiration. Must be null when the principal is a ServiceAccount.",
          "type": "string",
          "format": "date-time",
          "nullable": true
        },
        "groupRef": {
          "description": "groupRef specifies the TwingateGroup kubernetes object reference to provide access to.",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the TwingateGroup object.",
              "type": "string"
            },
            "namespace": {
              "description": "Namespace of TwingateGroup object.",
              "type": "string",
              "default": "default"
            }
          },
          "additionalProperties": false,
          "x-kubernetes-validations": [
            {
              "rule": "self == oldSelf",
              "message": "groupRef is immutable."
            }
          ]
        },
        "principalExternalRef": {
          "description": "principalExternalRef allows referencing a Principal (Group/ServiceAccount) by name.",
          "type": "object",
          "required": [
            "type",
            "name"
          ],
          "properties": {
            "name": {
              "description": "Name of the external reference to match. (Note: name uniqueness is not enforce, if 2 entities match the same name, the first will be used)",
              "type": "string",
              "x-kubernetes-validations": [
                {
                  "rule": "self == oldSelf",
                  "message": "principalExternalRef.name is immutable"
                }
              ]
            },
            "type": {
              "description": "Type of the external reference.",
              "type": "string",
              "enum": [
                "group",
                "serviceAccount"
              ],
              "x-kubernetes-validations": [
                {
                  "rule": "self == oldSelf",
                  "message": "principalExternalRef.type is immutable"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "principalId": {
          "description": "principalId is the ID of the principal (Group/ServiceAccount) to provide access to the resource.",
          "type": "string",
          "pattern": "^[-A-Za-z0-9+/]*={0,3}$",
          "x-kubernetes-validations": [
            {
              "rule": "self == oldSelf",
              "message": "principalId is immutable"
            }
          ]
        },
        "resourceRef": {
          "description": "resourceRef specifies the TwingateResource reference to provide access to.",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the resource.",
              "type": "string"
            },
            "namespace": {
              "description": "Namespace of the resource.",
              "type": "string",
              "nullable": true
            }
          },
          "additionalProperties": false,
          "x-kubernetes-validations": [
            {
              "rule": "self == oldSelf",
              "message": "resourceRef is immutable."
            }
          ]
        },
        "securityPolicyId": {
          "type": "string",
          "pattern": "^[-A-Za-z0-9+/]*={0,3}$",
          "nullable": true
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "x-kubernetes-preserve-unknown-fields": true
    }
  }
}
