              "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "has(self.workerDeploymentRef) || has(self.temporalWorkerDeploymentRef)",
          "message": "workerDeploymentRef must be set (or temporalWorkerDeploymentRef for migration compatibility)"
        },
        {
          "rule": "!(has(self.workerDeploymentRef) \u0026\u0026 has(self.temporalWorkerDeploymentRef))",
          "message": "only one of workerDeploymentRef or temporalWorkerDeploymentRef may be set"
        }
      ]
    },
    "status": {
