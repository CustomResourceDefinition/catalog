{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "secretRef"
      ],
      "properties": {
        "cmfRestClassRef": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "secretRef": {
          "type": "string",
          "maxLength": 63,
          "minLength": 1,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "properties": {
        "cfkInternalState": {
          "type": "string"
        },
        "cmfSync": {
          "type": "object",
          "required": [
            "errorMessage",
            "lastSyncTime"
          ],
          "properties": {
            "errorMessage": {
              "type": "string"
            },
            "lastSyncTime": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "default": "Unknown",
              "enum": [
                "Unknown",
                "Created",
                "Failed",
                "Deleted"
              ]
            }
          },
          "additionalProperties": false
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lastProbeTime": {
                "type": "string",
                "format": "date-time"
              },
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "observedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "observedSecretResourceVersion": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
