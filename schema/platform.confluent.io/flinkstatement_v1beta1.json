{
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "computePoolName",
        "flinkEnvironment",
        "statement"
      ],
      "properties": {
        "cmfRestClassRef": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "namespace": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "computePoolName": {
          "type": "string"
        },
        "flinkConfiguration": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "flinkEnvironment": {
          "type": "string",
          "minLength": 1,
          "x-kubernetes-validations": [
            {
              "rule": "self == oldSelf",
              "message": "flinkEnvironment is immutable"
            }
          ]
        },
        "parallelism": {
          "type": "integer",
          "format": "int32"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "startFromSavepoint": {
          "type": "object",
          "properties": {
            "allowNonRestoredState": {
              "type": "boolean"
            },
            "initialSavepointPath": {
              "type": "string"
            },
            "savepointName": {
              "type": "string"
            },
            "savepointRedeployNonce": {
              "type": "integer",
              "format": "int64"
            },
            "uid": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "statement": {
          "type": "string"
        },
        "stopped": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "self.statement == oldSelf.statement || oldSelf.statement == ''",
          "message": "statement is immutable once running"
        }
      ]
    },
    "status": {
      "type": "object",
      "required": [
        "phase"
      ],
      "properties": {
        "cfkInternalState": {
          "type": "string"
        },
        "cmfSync": {
          "type": "object",
          "required": [
            "errorMessage",
            "lastSyncTime"
          ],
          "properties": {
            "errorMessage": {
              "type": "string"
            },
            "lastSyncTime": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "default": "Unknown",
              "enum": [
                "Unknown",
                "Created",
                "Failed",
                "Deleted"
              ]
            }
          },
          "additionalProperties": false
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lastProbeTime": {
                "type": "string",
                "format": "date-time"
              },
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "detail": {
          "type": "string"
        },
        "observedGeneration": {
          "type": "integer",
          "format": "int64"
        },
        "phase": {
          "type": "string"
        },
        "resourceSummary": {
          "type": "object",
          "properties": {
            "jobManager": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "integer"
                },
                "cpu": {
                  "type": "number"
                },
                "memory": {
                  "type": "integer",
                  "format": "int64"
                }
              },
              "additionalProperties": false
            },
            "taskManager": {
              "type": "object",
              "properties": {
                "count": {
                  "type": "integer"
                },
                "cpu": {
                  "type": "number"
                },
                "memory": {
                  "type": "integer",
                  "format": "int64"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "traits": {
          "type": "object",
          "properties": {
            "isAppendOnly": {
              "type": "boolean"
            },
            "isBounded": {
              "type": "boolean"
            },
            "schema": {
              "type": "object",
              "required": [
                "columns"
              ],
              "properties": {
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "type"
                    ],
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "type": {
                        "x-kubernetes-preserve-unknown-fields": true
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "sqlKind": {
              "type": "string"
            },
            "upsertColumns": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            }
          },
          "additionalProperties": false
        },
        "warning": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
