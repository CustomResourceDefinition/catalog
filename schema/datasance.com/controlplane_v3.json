{
  "description": "ControlPlane is the Schema for the controlplanes API.",
  "type": "object",
  "properties": {
    "apiVersion": {
      "description": "APIVersion defines the versioned schema of this representation of an object.\nServers should convert recognized schemas to the latest internal value, and\nmay reject unrecognized values.\nMore info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#resources",
      "type": "string"
    },
    "kind": {
      "description": "Kind is a string value representing the REST resource this object represents.\nServers may infer this from the endpoint the client submits requests to.\nCannot be updated.\nIn CamelCase.\nMore info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#types-kinds",
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "description": "ControlPlaneSpec defines the desired state of ControlPlane.",
      "type": "object",
      "required": [
        "auth",
        "database"
      ],
      "properties": {
        "auth": {
          "description": "INSERT ADDITIONAL SPEC FIELDS - desired state of cluster\nImportant: Run \"operator-sdk generate k8s\" to regenerate code after modifying this file\nAdd custom validation using kubebuilder tags: https://book-v1.book.kubebuilder.io/beyond_basics/generating_crd.html\nAuth configures OIDC for the Controller (embedded or external IdP).",
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "bootstrap": {
              "description": "Bootstrap admin credentials; required when mode=embedded.",
              "type": "object",
              "properties": {
                "password": {
                  "type": "string"
                },
                "passwordSecretRef": {
                  "description": "PasswordSecretRef references a Secret containing the bootstrap password.",
                  "type": "object",
                  "required": [
                    "key"
                  ],
                  "properties": {
                    "key": {
                      "description": "The key of the secret to select from.  Must be a valid secret key.",
                      "type": "string"
                    },
                    "name": {
                      "description": "Name of the referent.\nThis field is effectively required, but due to backwards compatibility is\nallowed to be empty. Instances of this type with an empty value here are\nalmost certainly wrong.\nMore info: https://kubernetes.io/docs/concepts/overview/working-with-objects/names/#names",
                      "type": "string",
                      "default": ""
                    },
                    "optional": {
                      "description": "Specify whether the Secret or its key must be defined",
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false,
                  "x-kubernetes-map-type": "atomic"
                },
                "username": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "client": {
              "description": "Client OAuth2 credentials for the Controller API.",
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "secret": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "consoleClient": {
              "description": "ConsoleClient is the OIDC client id for EdgeOps Console (embedded only).",
              "type": "string"
            },
            "consoleClientEnabled": {
              "description": "ConsoleClientEnabled registers the console OIDC client (embedded only).",
              "type": "boolean"
            },
            "insecureAllowBootstrapLog": {
              "description": "InsecureAllowBootstrapLog logs bootstrap credentials (dev only).",
              "type": "boolean"
            },
            "insecureAllowHttp": {
              "description": "InsecureAllowHttp allows HTTP for OIDC endpoints (dev only).",
              "type": "boolean"
            },
            "issuerUrl": {
              "description": "IssuerUrl is required when mode=external.",
              "type": "string"
            },
            "mode": {
              "description": "Mode is required: embedded (local OIDC) or external (IdP).",
              "type": "string",
              "enum": [
                "embedded",
                "external"
              ]
            },
            "oidcTtl": {
              "description": "OidcTtl configures OIDC interaction/grant/session TTLs (embedded only).",
              "type": "object",
              "properties": {
                "grantTtlSeconds": {
                  "type": "integer"
                },
                "idTokenTtlSeconds": {
                  "type": "integer"
                },
                "interactionTtlSeconds": {
                  "type": "integer"
                },
                "sessionTtlSeconds": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            },
            "rateLimit": {
              "description": "RateLimit configures auth rate limiting (embedded only).",
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "maxRequestsPerWindow": {
                  "type": "integer"
                },
                "windowMs": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            },
            "sessionStore": {
              "description": "SessionStore configures session storage (embedded only).",
              "type": "object",
              "properties": {
                "secret": {
                  "type": "string"
                },
                "ttlMs": {
                  "type": "integer"
                },
                "type": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "tokenTtl": {
              "description": "TokenTtl configures access/refresh token TTLs (embedded only).",
              "type": "object",
              "properties": {
                "accessTokenTtlSeconds": {
                  "type": "integer"
                },
                "refreshTokenTtlSeconds": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "controller": {
          "description": "Controller contains runtime configuration for ioFog Controller",
          "type": "object",
          "properties": {
            "consolePort": {
              "type": "integer"
            },
            "consoleUrl": {
              "type": "string"
            },
            "ecn": {
              "type": "string"
            },
            "https": {
              "type": "boolean"
            },
            "logLevel": {
              "type": "string"
            },
            "pidBaseDir": {
              "type": "string"
            },
            "publicUrl": {
              "type": "string"
            },
            "secretName": {
              "type": "string"
            },
            "trustProxy": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "database": {
          "description": "Database for ioFog Controller",
          "type": "object",
          "required": [
            "databaseName",
            "host",
            "password",
            "port",
            "provider",
            "user"
          ],
          "properties": {
            "ca": {
              "type": "string"
            },
            "databaseName": {
              "type": "string"
            },
            "host": {
              "type": "string"
            },
            "password": {
              "type": "string"
            },
            "port": {
              "type": "integer"
            },
            "provider": {
              "type": "string"
            },
            "ssl": {
              "type": "boolean"
            },
            "user": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "events": {
          "description": "// Router contains runtime configuration for ioFog Router\nRouter Router `json:\"router,omitempty\"`\nEvents contains runtime configuration for ioFog Controller events",
          "type": "object",
          "properties": {
            "auditEnabled": {
              "type": "boolean"
            },
            "captureIpAddress": {
              "type": "boolean"
            },
            "cleanupInterval": {
              "type": "integer"
            },
            "retentionDays": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "images": {
          "description": "Images specifies which containers to run for each component of the ControlPlane",
          "type": "object",
          "properties": {
            "controller": {
              "type": "string"
            },
            "nats": {
              "type": "string"
            },
            "pullSecret": {
              "type": "string"
            },
            "router": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "ingresses": {
          "description": "Ingresses allow Router and Port Manager to configure endpoint addresses correctly",
          "type": "object",
          "properties": {
            "controller": {
              "type": "object",
              "properties": {
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "host": {
                  "type": "string"
                },
                "ingressClassName": {
                  "type": "string"
                },
                "secretName": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "nats": {
              "description": "NatsIngress specifies the external address and ports for NATS hub registration (required when using ingress).\nPorts are optional and default to: server 4222, cluster 6222, leaf 7422, mqtt 8883, http 8222.",
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "clusterPort": {
                  "type": "integer"
                },
                "httpPort": {
                  "type": "integer"
                },
                "leafPort": {
                  "type": "integer"
                },
                "mqttPort": {
                  "type": "integer"
                },
                "serverPort": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            },
            "router": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "edgePort": {
                  "type": "integer"
                },
                "interiorPort": {
                  "type": "integer"
                },
                "messagePort": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "nats": {
          "description": "Nats contains NATS hub configuration (StatefulSet, JetStream, etc.). When omitted, NATS is enabled with defaults.",
          "type": "object",
          "properties": {
            "enabled": {
              "description": "Enabled toggles NATS deployment. When omitted, treated as true.",
              "type": "boolean"
            },
            "jetStream": {
              "description": "JetStream storage and memory limits.",
              "type": "object",
              "properties": {
                "memoryStoreSize": {
                  "description": "MemoryStoreSize is used for max_memory_store in server.conf only (default 1Gi).",
                  "type": "string"
                },
                "storageClassName": {
                  "description": "StorageClassName for the JetStream PVC (optional).",
                  "type": "string"
                },
                "storageSize": {
                  "description": "StorageSize is used for the PVC size and max_file_store in server.conf (default 10Gi).",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "replicas": {
          "description": "Replicas of ioFog Controller should be 1 unless an external DB is configured",
          "type": "object",
          "properties": {
            "controller": {
              "type": "integer",
              "format": "int32"
            },
            "nats": {
              "description": "Nats is the number of NATS server replicas (default 2, min 2 when NATS enabled).",
              "type": "integer",
              "format": "int32",
              "minimum": 2
            }
          },
          "additionalProperties": false
        },
        "services": {
          "description": "Services should be LoadBalancer unless Ingress is being configured",
          "type": "object",
          "properties": {
            "controller": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "externalTrafficPolicy": {
                  "description": "ExternalTrafficPolicy for LoadBalancer/NodePort: \"Local\" or \"Cluster\". When omitted, LoadBalancer defaults to Local, others to Cluster. Use \"Cluster\" on local K8s (e.g. OrbStack) if Local causes issues.",
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "nats": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "externalTrafficPolicy": {
                  "description": "ExternalTrafficPolicy for LoadBalancer/NodePort: \"Local\" or \"Cluster\". When omitted, LoadBalancer defaults to Local, others to Cluster. Use \"Cluster\" on local K8s (e.g. OrbStack) if Local causes issues.",
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "natsServer": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "externalTrafficPolicy": {
                  "description": "ExternalTrafficPolicy for LoadBalancer/NodePort: \"Local\" or \"Cluster\". When omitted, LoadBalancer defaults to Local, others to Cluster. Use \"Cluster\" on local K8s (e.g. OrbStack) if Local causes issues.",
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "router": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "externalTrafficPolicy": {
                  "description": "ExternalTrafficPolicy for LoadBalancer/NodePort: \"Local\" or \"Cluster\". When omitted, LoadBalancer defaults to Local, others to Cluster. Use \"Cluster\" on local K8s (e.g. OrbStack) if Local causes issues.",
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "vault": {
          "description": "Vault is optional. When set, the Controller uses the configured vault provider for secrets. Operator creates a Secret from provider-specific config and injects env vars.",
          "type": "object",
          "properties": {
            "aws": {
              "description": "Aws provider config. Set when provider is aws or aws-secrets-manager.",
              "type": "object",
              "properties": {
                "accessKey": {
                  "type": "string"
                },
                "accessKeyId": {
                  "type": "string"
                },
                "region": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "azure": {
              "description": "Azure provider config. Set when provider is azure or azure-key-vault.",
              "type": "object",
              "properties": {
                "clientId": {
                  "type": "string"
                },
                "clientSecret": {
                  "type": "string"
                },
                "tenantId": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "basePath": {
              "description": "BasePath for secrets in vault; $namespace is replaced with the ControlPlane namespace (e.g. iofog/$namespace/secrets).",
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "google": {
              "description": "Google provider config. Set when provider is google or google-secret-manager.",
              "type": "object",
              "properties": {
                "credentials": {
                  "type": "string"
                },
                "projectId": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "hashicorp": {
              "description": "Hashicorp (and openbao/vault) provider config. Set when provider is hashicorp, openbao, or vault.",
              "type": "object",
              "properties": {
                "address": {
                  "type": "string"
                },
                "mount": {
                  "type": "string"
                },
                "token": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "provider": {
              "description": "Provider: hashicorp, openbao, vault, aws, aws-secrets-manager, azure, azure-key-vault, google, google-secret-manager.",
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "status": {
      "description": "ControlPlaneStatus defines the observed state of ControlPlane.",
      "type": "object",
      "required": [
        "conditions"
      ],
      "properties": {
        "conditions": {
          "description": "INSERT ADDITIONAL STATUS FIELD - define observed state of cluster\nImportant: Run \"make\" to regenerate code after modifying this file",
          "type": "array",
          "items": {
            "description": "Condition contains details for one aspect of the current state of this API Resource.",
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "description": "lastTransitionTime is the last time the condition transitioned from one status to another.\nThis should be when the underlying condition changed.  If that is not known, then using the time when the API field changed is acceptable.",
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "description": "message is a human readable message indicating details about the transition.\nThis may be an empty string.",
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "description": "observedGeneration represents the .metadata.generation that the condition was set based upon.\nFor instance, if .metadata.generation is currently 12, but the .status.conditions[x].observedGeneration is 9, the condition is out of date\nwith respect to the current state of the instance.",
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "description": "reason contains a programmatic identifier indicating the reason for the condition's last transition.\nProducers of specific condition types may define expected values and meanings for this field,\nand whether the values are considered a guaranteed API.\nThe value should be a CamelCase string.\nThis field may not be empty.",
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "description": "status of the condition, one of True, False, Unknown.",
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "description": "type of condition in CamelCase or in foo.example.com/CamelCase.",
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
