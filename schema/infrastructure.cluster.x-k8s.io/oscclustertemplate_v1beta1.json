                          "type": "string"
                        },
                        "imageId": {
                          "type": "string"
                        },
                        "imageName": {
                          "type": "string"
                        },
                        "keypairName": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "privateIps": {
                          "type": "array",
