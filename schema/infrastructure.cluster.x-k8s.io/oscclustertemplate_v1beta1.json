                        "subregionName": {
                          "description": "unused",
                          "type": "string"
                        },
                        "vmType": {
                          "description": "The type of VM (tinav6.c1r1p2 by default)",
                          "type": "string"
                        }
                      },
                      "additionalProperties": false
                    },
