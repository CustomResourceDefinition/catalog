                            "timeout": {
                              "description": "the Timeout to consider VM unhealthy",
                              "type": "integer",
                              "format": "int32"
                            },
                            "unhealthythreshold": {
                              "description": "the consecutive number of pings which are failed to consider the vm unhealthy",
                              "type": "integer",
                              "format": "int32"
                            }
