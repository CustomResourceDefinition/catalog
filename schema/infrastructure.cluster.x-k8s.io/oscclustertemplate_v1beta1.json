                            "loadbalancerport": {
                              "description": "The port on which the loadbalancer will listen",
                              "type": "integer",
                              "format": "int32"
                            },
                            "loadbalancerprotocol": {
                              "description": "the routing protocol ('HTTP'|'TCP')",
                              "type": "string"
