{
  "type": "object",
  "required": [
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "forceFullBackup": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "Push",
            "Pull"
          ]
        },
        "pvcName": {
          "type": "string"
        },
        "skipQuiesce": {
          "type": "boolean"
        },
        "source": {
          "type": "object",
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "apiGroup": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "x-kubernetes-map-type": "atomic",
          "x-kubernetes-validations": [
            {
              "rule": "has(self.apiGroup)",
              "message": "apiGroup is required"
            },
            {
              "rule": "!has(self.apiGroup) || self.apiGroup == 'kubevirt.io' || self.apiGroup == 'backup.kubevirt.io'",
              "message": "apiGroup must be kubevirt.io or backup.kubevirt.io"
            },
            {
              "rule": "!has(self.apiGroup) || (self.apiGroup == 'kubevirt.io' \u0026\u0026 self.kind == 'VirtualMachine') || (self.apiGroup == 'backup.kubevirt.io' \u0026\u0026 self.kind == 'VirtualMachineBackupTracker')",
              "message": "kind must be VirtualMachine for kubevirt.io or VirtualMachineBackupTracker for backup.kubevirt.io"
            },
            {
              "rule": "self.name != ''",
              "message": "name is required"
            }
          ]
        },
        "tokenSecretRef": {
          "type": "string"
        },
        "ttlDuration": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "self == oldSelf",
          "message": "spec is immutable after creation"
        },
        {
          "rule": "has(self.pvcName) \u0026\u0026 self.pvcName != \"\"",
          "message": "pvcName is required"
        },
        {
          "rule": "!has(self.mode) || self.mode != 'Pull' || (has(self.tokenSecretRef) \u0026\u0026 self.tokenSecretRef != \"\")",
          "message": "tokenSecretRef is required when mode is Pull"
        }
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "checkpointName": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "status",
              "type"
            ],
            "properties": {
              "lastProbeTime": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "message": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-type": "atomic"
        },
        "endpointCert": {
          "type": "string"
        },
        "includedVolumes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "diskTarget",
              "volumeName"
            ],
            "properties": {
              "dataEndpoint": {
                "type": "string"
              },
              "diskTarget": {
                "type": "string"
              },
              "mapEndpoint": {
                "type": "string"
              },
              "volumeName": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "x-kubernetes-list-type": "atomic"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
