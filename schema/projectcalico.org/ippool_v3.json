{
  "type": "object",
  "required": [
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "cidr"
      ],
      "properties": {
        "allowedUses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Workload",
              "Tunnel",
              "LoadBalancer"
            ]
          },
          "x-kubernetes-list-type": "set"
        },
        "assignmentMode": {
          "type": "string",
          "default": "Automatic",
          "enum": [
            "Automatic",
            "Manual"
          ]
        },
        "blockSize": {
          "type": "integer",
          "maximum": 128,
          "minimum": 0
        },
        "cidr": {
          "type": "string",
          "format": "cidr"
        },
        "disableBGPExport": {
          "type": "boolean"
        },
        "disabled": {
          "type": "boolean"
        },
        "ipipMode": {
          "type": "string",
          "enum": [
            "Never",
            "Always",
            "CrossSubnet"
          ]
        },
        "namespaceSelector": {
          "type": "string"
        },
        "natOutgoing": {
          "type": "boolean"
        },
        "nodeSelector": {
          "type": "string"
        },
        "vxlanMode": {
          "type": "string",
          "enum": [
            "Never",
            "Always",
            "CrossSubnet"
          ]
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "properties": {
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string",
                "maxLength": 32768
              },
              "observedGeneration": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ]
              },
              "type": {
                "type": "string",
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
