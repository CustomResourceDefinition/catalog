{
  "type": "object",
  "required": [
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "required": [
        "autoAllocateBlocks",
        "strictAffinity"
      ],
      "properties": {
        "autoAllocateBlocks": {
          "type": "boolean",
          "default": true
        },
        "kubeVirtVMAddressPersistence": {
          "type": "string",
          "enum": [
            "Enabled",
            "Disabled"
          ]
        },
        "maxBlocksPerHost": {
          "type": "integer",
          "format": "int32",
          "default": 0,
          "maximum": 1000000,
          "minimum": 0
        },
        "strictAffinity": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    }
  }
}
