{
  "type": "object",
  "required": [
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "type": "object",
      "properties": {
        "expectedIPs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kubernetes-list-type": "set"
        },
        "interfaceName": {
          "type": "string",
          "maxLength": 15
        },
        "node": {
          "type": "string",
          "maxLength": 253
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "port",
              "protocol"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer",
                "maximum": 65535,
                "minimum": 1
              },
              "protocol": {
                "pattern": "^.*",
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "string"
                  }
                ],
                "x-kubernetes-int-or-string": true
              }
            },
            "additionalProperties": false
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "x-kubernetes-list-type": "set"
        }
      },
      "additionalProperties": false,
      "x-kubernetes-validations": [
        {
          "rule": "(has(self.interfaceName) \u0026\u0026 size(self.interfaceName) \u003e 0) || (has(self.expectedIPs) \u0026\u0026 size(self.expectedIPs) \u003e 0)",
          "message": "at least one of interfaceName or expectedIPs must be specified",
          "reason": "FieldValueInvalid"
        },
        {
          "rule": "has(self.node) \u0026\u0026 size(self.node) \u003e 0",
          "message": "node must be specified",
          "reason": "FieldValueInvalid"
        }
      ]
    }
  }
}
