{
  "type": "object",
  "properties": {
    "spec": {
      "type": "object",
      "required": [
        "resourceSetName"
      ],
      "properties": {
        "encryptionConfigSecretName": {
          "description": "Name of the Secret containing the encryption config",
          "type": "string",
          "nullable": true
        },
        "resourceSetName": {
          "description": "Name of the ResourceSet CR to use for backup",
          "type": "string",
          "nullable": true
        },
        "retentionCount": {
          "type": "integer",
          "minimum": 1
        },
        "schedule": {
          "description": "Cron schedule for recurring backups",
          "type": "string",
          "example": {
            "Descriptors": "@midnight",
            "Standard crontab specs": "0 0 * * *"
          },
          "nullable": true
        },
        "storageLocation": {
          "type": "object",
          "properties": {
            "s3": {
              "type": "object",
              "properties": {
                "bucketName": {
                  "type": "string",
                  "nullable": true
                },
                "clientConfig": {
                  "type": "object",
                  "properties": {
                    "aws": {
                      "type": "object",
                      "properties": {
                        "dualStack": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false,
                      "nullable": true
                    }
                  },
                  "additionalProperties": false,
                  "nullable": true
                },
                "credentialSecretName": {
                  "type": "string",
                  "nullable": true
                },
                "credentialSecretNamespace": {
                  "type": "string",
                  "nullable": true
                },
                "endpoint": {
                  "type": "string",
                  "nullable": true
                },
                "endpointCA": {
                  "type": "string",
                  "nullable": true
                },
                "folder": {
                  "type": "string",
                  "nullable": true
                },
                "insecureTLSSkipVerify": {
                  "type": "boolean"
                },
                "region": {
                  "type": "string",
                  "nullable": true
                }
              },
              "additionalProperties": false,
              "nullable": true
            }
          },
          "additionalProperties": false,
          "nullable": true
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "properties": {
        "backupType": {
          "type": "string",
          "nullable": true
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "nullable": true
              },
              "lastUpdateTime": {
                "type": "string",
                "nullable": true
              },
              "message": {
                "type": "string",
                "nullable": true
              },
              "reason": {
                "type": "string",
                "nullable": true
              },
              "status": {
                "type": "string",
                "nullable": true
              },
              "type": {
                "type": "string",
                "nullable": true
              }
            },
            "additionalProperties": false
          },
          "nullable": true
        },
        "filename": {
          "type": "string",
          "nullable": true
        },
        "lastSnapshotTs": {
          "type": "string",
          "nullable": true
        },
        "nextSnapshotAt": {
          "type": "string",
          "nullable": true
        },
        "observedGeneration": {
          "type": "integer"
        },
        "storageLocation": {
          "type": "string",
          "nullable": true
        },
        "summary": {
          "type": "string",
          "nullable": true
        }
      },
      "additionalProperties": false
    }
  }
}
