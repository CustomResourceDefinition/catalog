{
  "type": "object",
  "properties": {
    "spec": {
      "type": "object",
      "required": [
        "backupFilename"
      ],
      "properties": {
        "backupFilename": {
          "type": "string",
          "nullable": true
        },
        "deleteTimeoutSeconds": {
          "type": "integer",
          "maximum": 10
        },
        "encryptionConfigSecretName": {
          "type": "string",
          "nullable": true
        },
        "ignoreErrors": {
          "type": "boolean"
        },
        "prune": {
          "type": "boolean",
          "nullable": true
        },
        "storageLocation": {
          "type": "object",
          "properties": {
            "s3": {
              "type": "object",
              "properties": {
                "bucketName": {
                  "type": "string",
                  "nullable": true
                },
                "clientConfig": {
                  "type": "object",
                  "properties": {
                    "aws": {
                      "type": "object",
                      "properties": {
                        "dualStack": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false,
                      "nullable": true
                    }
                  },
                  "additionalProperties": false,
                  "nullable": true
                },
                "credentialSecretName": {
                  "type": "string",
                  "nullable": true
                },
                "credentialSecretNamespace": {
                  "type": "string",
                  "nullable": true
                },
                "endpoint": {
                  "type": "string",
                  "nullable": true
                },
                "endpointCA": {
                  "type": "string",
                  "nullable": true
                },
                "folder": {
                  "type": "string",
                  "nullable": true
                },
                "insecureTLSSkipVerify": {
                  "type": "boolean"
                },
                "region": {
                  "type": "string",
                  "nullable": true
                }
              },
              "additionalProperties": false,
              "nullable": true
            }
          },
          "additionalProperties": false,
          "nullable": true
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "properties": {
        "backupSource": {
          "type": "string",
          "nullable": true
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lastTransitionTime": {
                "type": "string",
                "nullable": true
              },
              "lastUpdateTime": {
                "type": "string",
                "nullable": true
              },
              "message": {
                "type": "string",
                "nullable": true
              },
              "reason": {
                "type": "string",
                "nullable": true
              },
              "status": {
                "type": "string",
                "nullable": true
              },
              "type": {
                "type": "string",
                "nullable": true
              }
            },
            "additionalProperties": false
          },
          "nullable": true
        },
        "observedGeneration": {
          "type": "integer"
        },
        "restoreCompletionTs": {
          "type": "string",
          "nullable": true
        },
        "summary": {
          "type": "string",
          "nullable": true
        }
      },
      "additionalProperties": false
    }
  }
}
